class Solution {
    public int minimumDifference(int[] nums, int k) {
        if(k==1)return 0;
        int n=nums.length;
        int min=Integer.MAX_VALUE;
        Arrays.sort(nums);
        for(int i=0;i<n-k+1;i++){
            if(min>nums[i+k-1]-nums[i])
                min=nums[i+k-1]-nums[i];
        }
        return min;
    }
}
