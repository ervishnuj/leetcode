class ApplyOperationsToAnArray {
    public int[] applyOperations(int[] nums) {
        int left =0,right=0;
        int n=nums.length;
        int[] arr=new int[n];
        for(int i=0;i<n-1;i++){
            if(nums[i]==nums[i+1]){
                nums[i]*=2;
                nums[i+1]=0;
            }
        }
        int k=0;
        for(int i:nums)if(i!=0)arr[k++]=i;
        return arr;
    }
}
