class BalancedStrings {
    public int balancedStringSplit(String s) {
        int len=s.length();
        int bal=0;
        int leftBal=0;
        int rightBal=0;
        for(int i=0;i<len;i++){
            char ch=s.charAt(i);
            if(ch=='L')leftBal++;
            else if(ch=='R')rightBal++;
            if(leftBal==rightBal){
                leftBal=0;rightBal=0;
                bal++;
            }
        }
        return bal;
    }
}
