class Solution {
    int maxDep=0;
    public int maxDepth(Node root) {
        depth(root,0);
        return maxDep;
    }
    private void depth(Node root,int dep){
        if(root==null)return;
        for(Node node:root.children){
            depth(node,dep+1);
        }
        maxDep=Math.max(maxDep,dep+1);
    }
}
