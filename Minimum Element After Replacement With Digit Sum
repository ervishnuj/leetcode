class Solution {
    public int minElement(int[] nums) {
        int min=Integer.MAX_VALUE;

        for(int i:nums){
            int j=i;
            int temp=0;
            while(j>0){
                temp+=j%10;
                j/=10;
                 

            }
            //if(temp<min)min=temp;
            min=Math.min(min,temp);
            
        }
        return min;
    
    }
}