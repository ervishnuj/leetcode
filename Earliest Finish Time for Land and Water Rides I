class Solution {
    public int earliestFinishTime(int[] landStartTime, int[] landDuration,
                                  int[] waterStartTime, int[] waterDuration) {

        int min = Integer.MAX_VALUE;

        // Land → Water
        for (int i = 0; i < landStartTime.length; i++) {

            int endLand = landStartTime[i] + landDuration[i];

            for (int j = 0; j < waterStartTime.length; j++) {

                int startWater = Math.max(endLand, waterStartTime[j]); // NEW variable
                int endWater = startWater + waterDuration[j];

                min = Math.min(min, endWater);
            }
        }

        // Water → Land
        for (int j = 0; j < waterStartTime.length; j++) {

            int endWater = waterStartTime[j] + waterDuration[j];

            for (int i = 0; i < landStartTime.length; i++) {

                int startLand = Math.max(endWater, landStartTime[i]); // NEW variable
                int endLand = startLand + landDuration[i];

                min = Math.min(min, endLand);
            }
        }

        return min;
    }
}
