class Solution {
    public int singleNonDuplicate(int[] nums) {
        int i=0;
        int res=nums[0];int j=1;
        for(;j<nums.length;j++){
            if(nums[i]!=nums[j]){
                if(j-i==1)res=nums[i];
                i=j;
            }
        }
        return j-i==1?nums[i]:res;
    }
}
