class Solution {
    public int smallestRangeI(int[] nums, int k) {
        int min=nums[0];
        int max=nums[0];
        for(int i=1;i<nums.length;i++){
            if(min>nums[i])min=nums[i];
            if(max<nums[i])max=nums[i];
        }
        int res=max-k-min-k;
        return Math.max(res,0);
    }
}
