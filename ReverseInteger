class ReverseInteger {
    public int reverse(int x) {
     int y=Math.abs(x);
     long result=0;
     while(y>0){
        result*=10;
        result+=y%10;
        y/=10;
     }   
     if(x<0)return -result<(long)Integer.MIN_VALUE?0:-(int)result;
     return result>(long)Integer.MAX_VALUE?0:(int)result;
    }
}
