class Solution {
    public boolean checkIfExist(int[] arr) {
      
        HashSet<Integer> set =new HashSet<>();
        int n=arr.length;
        for(Integer ii:arr){
             if(set.contains(ii*2))return true;

            if(ii%2==0&&set.contains(ii/2))return true;
            set.add(ii);
        }
        
        return false;
    }
}
