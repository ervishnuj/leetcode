class Solution {
    public int minAbsoluteDifference(int[] nums) {
        int size=nums.length;
        int min=size;
        for(int i=0;i<size;i++){
            for(int j=i+1;j<size;j++){
                if(((nums[i]==1&&nums[j]==2)||(nums[i]==2&&nums[j]==1))&&min>Math.abs(i-j)){
                    min=Math.abs(i-j);
                }
            }
        }
        return min==size?-1:min;
    }
}
