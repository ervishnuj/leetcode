class Solution {
    public int bitwiseComplement(int n) {
        if(n==0)return 1;
        int res=0;
        int pos=0;
        while(n>0){
            int temp=n%2;
            // res+=temp==0?2:0;
            if(temp==0){
                res+=1<<pos;
            }
            pos++;
            n/=2;
        }
        return res;
    }
}
