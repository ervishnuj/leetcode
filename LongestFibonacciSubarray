class Solution {
    public int longestSubarray(int[] nums) {
        int i=0;
        int max=2;
        for(int j=2;j<nums.length;j++){
            if(nums[j]==nums[j-1]+nums[j-2]){
                if(j-i+1>max)max=j-i+1;
            }else{
                i=j-1;
            }
        }
        return max;
    }
}
